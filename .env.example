# Path to folder containing PDF files (Google Drive sync path)
# macOS/Linux:
PDF_FOLDER=~/Google Drive/My Drive/検体受付_CIDP/01_初回登録
# Windows:
# PDF_FOLDER=C:\Users\YourName\Google Drive\My Drive\検体受付_CIDP\01_初回登録

# Google Sheet ID (from the sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit)
GOOGLE_SHEET_ID=your-sheet-id-here

# Path to GCP service account JSON key file
SERVICE_ACCOUNT_JSON=credentials.json

# --- opendataloader-pdf (primary PDF extraction engine) ---
# Set to "false" to disable and use Tesseract only
# USE_OPENDATALOADER=true
# Enable hybrid mode for AI-backed OCR (requires: opendataloader-pdf-hybrid --port 5002)
# OPENDATALOADER_HYBRID=false
# Force OCR on all pages (recommended for scanned documents)
# OPENDATALOADER_FORCE_OCR=true

# --- Tesseract (fallback) ---
# Windows only: path to poppler bin directory and tesseract executable
# Download poppler: https://github.com/osber/poppler-windows/releases
# Download tesseract: https://github.com/UB-Mannheim/tesseract/wiki
# POPPLER_PATH=C:\poppler\Library\bin
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
